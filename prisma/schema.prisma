// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions  Session[]
  accounts  Account[]
  reviews         Review[]
  characters      Character[]
  generatedImages GeneratedCharacterImage[]
  posts Post[]
  generatedBookCover GeneratedBookCover[]
  coverLikes         CoverLike[]
  characterImageLikes CharacterImageLike[]
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model BookSeries {
  id String @id @default(cuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("book_series")

  books Book[]
}

model Book {
  id            String   @id @default(cuid())
  googleBooksId String   @unique
  title         String
  authors       String   // comma-separated list
  description   String?
  thumbnailUrl  String?
  language      String?
  publishedDate String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews         Review[]
  characters      Character[]
  characterDescriptions CharacterDescription[]
  posts Post[]
  bookSeriesId String?
  bookSeries BookSeries? @relation(fields: [bookSeriesId], references: [id], onDelete: SetNull)

  generatedBookCover GeneratedBookCover[]
  generatedCharacterImages GeneratedCharacterImage[]

  @@index([googleBooksId])
  @@index([title])
}

model Post {
  id  String   @id @default(cuid())
  content String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([createdAt])

  @@map("post")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId, createdAt])
}

model Character {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  books                 Book[]
  generatedImages       GeneratedCharacterImage[]
  posts                 Post[]
  characterDescriptions CharacterDescription[]

  @@index([name])
}

model CharacterDescription {
  id String @id @default(cuid())
  description String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characterId String
  bookId String
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, bookId])
  @@unique([bookId, characterId])
  @@map("character_description")
}

model GeneratedBookCover {
  id String @id @default(cuid())
  blobUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  prompt String

  bookId String
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes CoverLike[]

  @@index([bookId])
}

model CoverLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId  String
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverId String
  cover   GeneratedBookCover @relation(fields: [coverId], references: [id], onDelete: Cascade)

  @@unique([userId, coverId])
  @@index([coverId])
  @@map("cover_like")
}

model CharacterImageLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId  String
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId String
  character   GeneratedCharacterImage @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([characterId])
  @@map("character_image_like")
}

model GeneratedCharacterImage {
  id        String   @id @default(cuid())
  prompt    String
  blobUrl   String
  createdAt DateTime @default(now())

  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  likes CharacterImageLike[]
  bookId String
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, characterId])
  @@index([userId])
  @@index([characterId])
  @@index([bookId])
}
